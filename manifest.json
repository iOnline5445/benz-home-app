{
  "manifest_version": 3,
  "name": "BENZ HOME Agency",
  "version": "1.0.0",
  "description": "Chrome Extension for BENZ HOME Agency Asset Management",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "BENZ HOME Agency",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
